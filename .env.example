# Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Database Configuration
POSTGRES_DB=supply-chain-scenario-rag
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://user:changeme@localhost:5432/supply-chain-scenario-rag
DB_ECHO=false

# API Configuration
DEBUG=true
ALLOWED_HOSTS=["http://localhost:5173"]

# UI Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# OpenShift/Deployment Configuration
# These are used by make deploy
# REGISTRY_URL is auto-detected from oc registry info if not set
# REGISTRY_URL=default-route-openshift-image-registry.apps.example.com
NAMESPACE=supply-chain-scenario-rag
IMAGE_TAG=latest
